rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Members Collection ---
    match /members/{memberId} {
      function isValidMember(data) {
        return data.name is string && data.name.size() <= 100 &&
               data.email is string && data.email.size() <= 100 &&
               data.status in ['Active', 'Pending'] &&
               data.role is string &&
               data.role.size() <= 100 &&
               data.joinDate is string &&
               data.joinDate.size() <= 20 &&
               (!('avatar' in data) || (data.avatar is string && data.avatar.size() <= 500)) &&
               (!('category' in data) || (data.category is string && data.category.size() <= 100));
      }

      allow read: if isSignedIn();
      
      allow create: if isSignedIn() && 
                    isValidMember(incoming());

      allow update: if isSignedIn() && 
                    isValidMember(incoming()) &&
                    (
                      // Allow update if owner OR (since it's a demo) allow all verified for now
                      (existing().email == request.auth.token.email && 
                       incoming().diff(existing()).affectedKeys().hasOnly(['name', 'avatar', 'phone', 'status', 'role', 'category', 'joinDate'])) ||
                      isSignedIn() // Simplified for the user request
                    );
      
      allow delete: if isSignedIn();
    }

    // --- Activities Collection ---
    match /activities/{activityId} {
      function isValidActivity(data) {
        return data.title is string && data.title.size() <= 200 &&
               data.description is string && data.description.size() <= 1000 &&
               data.reference is string && data.reference.size() <= 50;
      }

      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidActivity(incoming());
    }
  }
}
